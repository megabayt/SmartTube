<?xml version="1.0" encoding="utf-8"?>
<!-- MOD: Enable single click touch mode (focusableInTouchMode=false) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:tools="http://schemas.android.com/tools"
              android:focusableInTouchMode="true"
              android:focusable="true"
              android:orientation="vertical"
              android:gravity="center"
              android:layout_width="@dimen/settings_card_width"
              android:layout_height="@dimen/settings_card_height"
              android:paddingStart="12dp"
              android:paddingTop="14dp"
              android:paddingEnd="12dp"
              android:paddingBottom="12dp">
    <ImageView
        android:id="@+id/settings_image"
        android:layout_width="@dimen/settings_image_size"
        android:layout_height="@dimen/settings_image_size"
        android:layout_gravity="center"
        android:layout_marginBottom="10dp"
        android:visibility="invisible"
        tools:ignore="ContentDescription"/>
    <com.liskovsoft.smartyoutubetv2.tv.ui.widgets.marqueetextviewcompat.MarqueeTextViewCompat
        android:id="@+id/settings_title"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textAlignment="center"/>
</LinearLayout>
